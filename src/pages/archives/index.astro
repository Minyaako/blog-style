---
import ArchiveGroup from '../../components/ArchiveGroup.astro'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getPublishedPosts, groupPostsByYear, toPostCard } from '../../lib/posts'

const posts = await getPublishedPosts()
const groups = [...groupPostsByYear(posts)].map(([year, entries]) => ({ year, posts: entries.map(toPostCard) }))
---

<BaseLayout title="归档" description="按时间浏览主题仓库中的样例文章。">
  <div class="listing-page">
    <header class="page-heading"><p>Archive</p><h1>文章归档</h1><span>从最近的记录向过去漫游。</span></header>
    {groups.map((group) => <ArchiveGroup {...group} />)}
  </div>
</BaseLayout>

<style>
  .listing-page { width: min(100% - 2rem, var(--content-wide)); margin-inline: auto; padding-block: var(--space-7); }
  .page-heading { padding-bottom: var(--space-6); border-bottom: 1px solid var(--border-strong); }
  .page-heading p { margin: 0; color: var(--accent); font: var(--text-caption)/1.4 var(--font-mono); letter-spacing: .12em; text-transform: uppercase; }
  h1 { margin: var(--space-2) 0; font: 760 clamp(2.2rem, 7vw, 4.5rem)/1.05 var(--font-display); }
  .page-heading span { color: var(--text-muted); }
</style>
