---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="搜索" description="搜索主题仓库中的样例文章、标签与合集。">
  <link slot="head" href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script slot="head" is:inline src="/pagefind/pagefind-ui.js"></script>
  <script slot="head" is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      const fallback = document.querySelector('#search-fallback')
      try {
        new window.PagefindUI({ element: '#search', showSubResults: true, translations: { placeholder: '搜索文章、标签与合集', zero_results: '没有找到 [SEARCH_TERM] 的结果' } })
        document.querySelector('.pagefind-ui__search-input')?.setAttribute('role', 'searchbox')
      } catch (error) {
        if (fallback instanceof HTMLElement) fallback.hidden = false
        console.warn('Pagefind failed to initialize', error)
      }
    })
  </script>
  <div class="search-page"><header><p>Search</p><h1>搜索</h1><span>全文索引在构建时生成，不需要远端搜索服务。</span></header><div id="search"></div><p id="search-fallback" hidden>搜索组件暂时无法加载，你仍可前往 <a href="/archives">文章归档</a> 浏览全部内容。</p></div>
</BaseLayout>
<style>.search-page{width:min(100% - 2rem,var(--content-wide));min-height:65vh;margin-inline:auto;padding-block:var(--space-7)}header{padding-bottom:var(--space-6);border-bottom:1px solid var(--border-strong)}header p{margin:0;color:var(--accent);font:var(--text-caption)/1.4 var(--font-mono);letter-spacing:.12em;text-transform:uppercase}h1{margin:var(--space-2) 0;font:760 clamp(2.5rem,8vw,5rem)/1 var(--font-display)}header span,#search-fallback{color:var(--text-muted)}#search{margin-top:var(--space-6)}#search-fallback{padding:var(--space-5);border:1px solid var(--border);border-radius:var(--radius-md)}</style>
