---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getAllTags } from '../../lib/tags'
const tags = getAllTags()
---
<BaseLayout title="标签" description="浏览固定标签注册表。">
  <div class="tag-index">
    <header><p>Tags</p><h1>标签</h1><span>显示名称可以修改，稳定 ID 与文章引用保持不变。</span></header>
    <ul>{tags.map((tag) => <li><a href={`/tags/${tag.id}`}><strong>{tag.label}</strong><code>{tag.id}</code><span>{tag.description}</span></a></li>)}</ul>
  </div>
</BaseLayout>
<style>.tag-index{width:min(100% - 2rem,var(--content-wide));margin-inline:auto;padding-block:var(--space-7)}header{padding-bottom:var(--space-5);border-bottom:1px solid var(--border-strong)}header p{color:var(--accent);font:var(--text-caption)/1.4 var(--font-mono);text-transform:uppercase}h1{margin:var(--space-2) 0;font:750 clamp(2.2rem,7vw,4.5rem)/1.05 var(--font-display)}header span,li span{color:var(--text-muted)}ul{display:grid;grid-template-columns:repeat(auto-fit,minmax(15rem,1fr));gap:var(--space-4);padding:0;margin-top:var(--space-6);list-style:none}a{display:grid;gap:var(--space-2);height:100%;padding:var(--space-5);border:1px solid var(--border);border-radius:var(--radius-md);text-decoration:none}strong{font-size:1.2rem}code{color:var(--accent)}</style>
