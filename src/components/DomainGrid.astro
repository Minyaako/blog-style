---
import { DOMAINS, type DomainKey } from '../config/taxonomy'

const domains = Object.entries(DOMAINS) as [DomainKey, (typeof DOMAINS)[DomainKey]][]
---

<section class="domain-section" aria-labelledby="domain-heading">
  <div class="section-heading">
    <div><span>Explore</span><h2 id="domain-heading">四个内容领域</h2></div>
    <a href="/archives">查看全部归档 →</a>
  </div>
  <div class="domain-grid">
    {domains.map(([key, domain], index) => (
      <a class="domain-card" data-domain={key} href={`/domains/${key}`} aria-label={`${domain.label}：${domain.description}`}>
        <span class="index">0{index + 1}</span>
        <h3>{domain.label}</h3>
        <p>{domain.description}</p>
        <span class="english">{domain.englishLabel} ↗</span>
      </a>
    ))}
  </div>
</section>

<style>
  .domain-section { padding-block: var(--space-7); }
  .section-heading { display: flex; justify-content: space-between; align-items: end; margin-bottom: var(--space-4); }
  .section-heading span { color: var(--text-muted); font: var(--text-caption)/1 var(--font-mono); letter-spacing: 0.12em; text-transform: uppercase; }
  h2 { margin: var(--space-2) 0 0; font: 750 var(--text-title)/1.2 var(--font-display); }
  .section-heading > a { color: var(--text-muted); font-size: 0.82rem; }
  .domain-grid { display: grid; grid-template-columns: repeat(4, 1fr); border-block: 1px solid var(--border-strong); }
  .domain-card {
    position: relative;
    min-height: 12rem;
    padding: var(--space-5);
    border-right: 1px solid var(--border);
    text-decoration: none;
    transition: background var(--duration), translate var(--duration) var(--ease-out);
  }
  .domain-card:last-child { border-right: 0; }
  .domain-card:hover { background: var(--surface); translate: 0 -3px; }
  .domain-card::after { content: ''; position: absolute; inset: auto var(--space-5) 0; height: 3px; background: var(--domain-color); scale: 0 1; transform-origin: left; transition: scale var(--duration) var(--ease-out); }
  .domain-card:hover::after, .domain-card:focus-visible::after { scale: 1; }
  [data-domain='academic'] { --domain-color: var(--academic); }
  [data-domain='engineering'] { --domain-color: var(--engineering); }
  [data-domain='life'] { --domain-color: var(--life); }
  [data-domain='games'] { --domain-color: var(--games); }
  .index, .english { color: var(--text-muted); font: var(--text-caption)/1.2 var(--font-mono); }
  h3 { margin: var(--space-4) 0 var(--space-2); font: 700 1.3rem/1.2 var(--font-display); }
  p { min-height: 3.4em; color: var(--text-muted); font-size: 0.88rem; line-height: 1.7; }
  @media (max-width: 52rem) { .domain-grid { grid-template-columns: repeat(2, 1fr); } .domain-card:nth-child(2) { border-right: 0; } }
  @media (max-width: 32rem) { .domain-grid { grid-template-columns: 1fr; } .domain-card { min-height: 0; border-right: 0; border-bottom: 1px solid var(--border); } }
</style>
