---
import type { CollectionEntry } from 'astro:content'
import { DOMAINS, getSubcategory } from '../config/taxonomy'
interface Props { data: CollectionEntry<'posts'>['data']; minutes: number }
const { data, minutes } = Astro.props
const domain = DOMAINS[data.domain]
const subcategory = getSubcategory(data.domain, data.subcategory)
const formatDate = (date: Date) => new Intl.DateTimeFormat('zh-CN', { dateStyle: 'long' }).format(date)
---
<div class="article-meta"><p class="eyebrow"><a href={`/domains/${data.domain}`}>{domain.label}</a> / <a href={`/domains/${data.domain}/${data.subcategory}`}>{subcategory.label}</a></p><div class="facts"><span>发布于 <time datetime={data.publishedAt.toISOString()}>{formatDate(data.publishedAt)}</time></span>{data.updatedAt && <span>更新于 <time datetime={data.updatedAt.toISOString()}>{formatDate(data.updatedAt)}</time></span>}<span>{minutes} 分钟阅读</span><span>作者：{data.authors.join('、')}</span></div><ul aria-label="文章标签">{data.tags.map((tag) => <li><a href={`/tags/${encodeURIComponent(tag)}`}>#{tag}</a></li>)}</ul></div>
<style>
  .article-meta{display:grid;gap:var(--space-4);color:var(--text-muted)}.eyebrow{margin:0;color:var(--accent);font:var(--text-caption)/1.4 var(--font-mono);letter-spacing:.08em;text-transform:uppercase}a{color:inherit;text-underline-offset:.2em}.facts{display:flex;flex-wrap:wrap;gap:var(--space-2) var(--space-5);font-size:.82rem}ul{display:flex;flex-wrap:wrap;gap:var(--space-2);margin:0;padding:0;list-style:none}li a{display:block;padding:var(--space-1) var(--space-3);border:1px solid var(--border);border-radius:99rem;font-size:.76rem;text-decoration:none}
</style>
