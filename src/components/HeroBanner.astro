---
const slides = [
  {
    src: '/images/home/banner-geometric.svg',
    alt: '首页横幅：暮色几何风景',
    width: 1600,
    height: 520
  },
  {
    src: '/images/posts/academic-cover.svg',
    alt: '首页横幅：学术主题几何构图',
    width: 1200,
    height: 800
  }
]
---

<figure class="hero-banner" data-hero-rotator>
  {slides.map((slide, index) => (
    <img
      src={slide.src}
      alt={slide.alt}
      width={slide.width}
      height={slide.height}
      loading="eager"
      fetchpriority={index === 0 ? 'high' : 'low'}
      data-hero-slide
      data-active={index === 0 ? 'true' : 'false'}
      aria-hidden={index === 0 ? 'false' : 'true'}
    />
  ))}
  <figcaption>Neutral preview assets · Replace in the content repository</figcaption>
</figure>

<script>
  const intervalMs = 60_000

  document.querySelectorAll<HTMLElement>('[data-hero-rotator]').forEach((rotator) => {
    if (rotator.dataset.initialized === 'true') return
    rotator.dataset.initialized = 'true'

    const slides = Array.from(rotator.querySelectorAll<HTMLElement>('[data-hero-slide]'))
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)')
    let activeIndex = 0
    let timer: number | undefined

    const show = (index: number) => {
      activeIndex = index
      slides.forEach((slide, slideIndex) => {
        const active = slideIndex === activeIndex
        slide.dataset.active = String(active)
        slide.setAttribute('aria-hidden', String(!active))
      })
    }

    const stop = () => {
      if (timer !== undefined) window.clearInterval(timer)
      timer = undefined
    }

    const start = () => {
      stop()
      if (reducedMotion.matches || document.hidden || slides.length < 2) return
      timer = window.setInterval(() => show((activeIndex + 1) % slides.length), intervalMs)
    }

    document.addEventListener('visibilitychange', start)
    reducedMotion.addEventListener('change', () => {
      if (reducedMotion.matches) show(0)
      start()
    })
    start()
  })
</script>

<style>
  .hero-banner {
    position: relative;
    overflow: hidden;
    aspect-ratio: 40 / 13;
    margin: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    box-shadow: var(--shadow-soft);
  }

  img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    pointer-events: none;
    transition: opacity 1.2s ease;
  }

  img[data-active='true'] { opacity: 1; }

  figcaption {
    position: absolute;
    inset: auto auto var(--space-3) var(--space-4);
    color: #f7f2eb;
    font-family: var(--font-mono);
    font-size: 0.67rem;
    letter-spacing: 0.08em;
    text-shadow: 0 1px 6px rgb(0 0 0 / 0.65);
  }

  @media (max-width: 40rem) {
    .hero-banner { aspect-ratio: 16 / 8.5; }
    figcaption { inset-inline: var(--space-3); }
  }

  @media (prefers-reduced-motion: reduce) {
    img { transition: none; }
  }
</style>
