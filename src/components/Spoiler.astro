---
interface Props { label?: string }
const { label = '显示剧透内容' } = Astro.props
const id = `spoiler-${Math.random().toString(36).slice(2)}`
---
<div class="spoiler"><button type="button" aria-expanded="false" aria-controls={id}>{label}</button><div id={id} class="spoiler-content" aria-hidden="true"><slot /></div></div>
<script>
  document.querySelectorAll('.spoiler').forEach((root) => {
    const button = root.querySelector('button')
    const content = root.querySelector('.spoiler-content')
    button?.addEventListener('click', () => {
      const expanded = button.getAttribute('aria-expanded') !== 'true'
      button.setAttribute('aria-expanded', String(expanded))
      content?.setAttribute('aria-hidden', String(!expanded))
    })
  })
</script>
<style>.spoiler{margin-block:var(--space-5)}button{padding:var(--space-2) var(--space-3);border:1px solid var(--border);border-radius:99rem;background:var(--surface);color:var(--text);cursor:pointer}.spoiler-content{margin-top:var(--space-3);padding:var(--space-4);border-radius:var(--radius-md);background:var(--surface);filter:blur(.55rem);user-select:none;transition:filter 160ms ease}.spoiler-content[aria-hidden='false']{filter:none;user-select:auto}</style>
