---
import { Icon } from 'astro-icon/components'

interface Props {
  name: string
  label?: string
  size?: number
}

const { name, label, size = 18 } = Astro.props
---

<Icon
  name={name}
  size={size}
  role={label ? 'img' : undefined}
  aria-label={label}
  aria-hidden={label ? undefined : 'true'}
  focusable="false"
/>
