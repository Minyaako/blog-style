---
import type { MarkdownHeading } from 'astro'
import type { CollectionEntry } from 'astro:content'
import ArticleMeta from '../components/ArticleMeta.astro'
import ContentWarningDialog from '../components/ContentWarningDialog.astro'
import ContentNotice from '../components/ContentNotice.astro'
import TableOfContents from '../components/TableOfContents.astro'
import type { PostCardData } from '../lib/posts'
import BaseLayout from './BaseLayout.astro'
interface Props { post: CollectionEntry<'posts'>; headings: MarkdownHeading[]; minutes: number; previous?: PostCardData; next?: PostCardData }
const { post, headings, minutes, previous, next } = Astro.props
const { data } = post
const protectedPage = data.contentWarning.type !== 'none' && data.contentWarning.scope === 'page'
const safeDescription = protectedPage ? '此内容需要确认后查看。' : data.description
---
<BaseLayout title={data.title} description={safeDescription} image={data.contentWarning.type === 'none' ? data.cover?.url : undefined}>
  {protectedPage && <ContentWarningDialog pageKey={data.id} message={data.contentWarning.message} returnHref={`/domains/${data.domain}`} />}
  <article class="article" data-domain={data.domain}>
    <header class="article-header"><ArticleMeta data={data} minutes={minutes} /><h1>{data.title}</h1><p class="dek">{data.description}</p></header>
    {data.cover && <figure class="cover"><img src={data.cover.url} alt={data.cover.alt} width="1200" height="630" /><figcaption>图：{data.cover.credit}</figcaption></figure>}
    <div class="article-grid"><aside class="toc-column"><TableOfContents headings={headings} /></aside><div class="prose" data-pagefind-body={!protectedPage ? true : undefined} data-pagefind-ignore={protectedPage ? true : undefined}><slot /></div></div>
    <ContentNotice data={data} />
    <nav class="article-pagination" aria-label="前后文章">{previous ? <a href={`/posts/${previous.slug}`}><span>上一篇</span>{previous.title}</a> : <span />}{next && <a href={`/posts/${next.slug}`}><span>下一篇</span>{next.title}</a>}</nav>
    <section class="comment-slot" data-comment-slot data-page-key={data.id} data-pagefind-ignore aria-label="评论区"><p>评论服务将在页面加载后由独立适配器接入。</p></section>
  </article>
</BaseLayout>
<style>
  .article{width:min(100% - 2rem,var(--content-wide));margin-inline:auto;padding-block:var(--space-7)}.article-header{max-width:58rem;margin-inline:auto;text-align:center}.article-header :global(.article-meta){justify-items:center}h1{margin:var(--space-5) auto var(--space-4);font:780 clamp(2.15rem,5.5vw,4.6rem)/1.08 var(--font-display);letter-spacing:-.035em}.dek{max-width:52ch;margin:0 auto;color:var(--text-muted);font-size:clamp(1rem,.92rem + .35vw,1.25rem);line-height:1.7}.cover{margin:var(--space-7) 0}.cover img{width:100%;max-height:38rem;border-radius:var(--radius-lg);object-fit:cover}figcaption{margin-top:var(--space-2);color:var(--text-muted);font-size:.76rem;text-align:right}.article-grid{display:grid;grid-template-columns:12rem minmax(0,var(--prose));justify-content:center;gap:clamp(2rem,5vw,5rem);margin-top:var(--space-7)}.toc-column{position:sticky;top:6rem;align-self:start;max-height:calc(100vh - 8rem);overflow-y:auto}.article-pagination{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:var(--space-4);margin-top:var(--space-7);padding-top:var(--space-5);border-top:1px solid var(--border)}.article-pagination a{padding:var(--space-4);border:1px solid var(--border);border-radius:var(--radius-md);text-decoration:none}.article-pagination a:last-child{text-align:right}.article-pagination span{display:block;margin-bottom:var(--space-2);color:var(--text-muted);font:var(--text-caption)/1.3 var(--font-mono)}.comment-slot{margin-top:var(--space-7);padding:var(--space-6);border:1px dashed var(--border-strong);border-radius:var(--radius-md);color:var(--text-muted);text-align:center}@media(max-width:54rem){.article-grid{grid-template-columns:minmax(0,var(--prose))}.toc-column{position:static;padding:var(--space-4);border:1px solid var(--border);border-radius:var(--radius-md)}}@media(max-width:44rem){.article-pagination{grid-template-columns:1fr}}
</style>
